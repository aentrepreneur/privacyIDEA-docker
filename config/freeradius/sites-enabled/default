# sites-enabled/default — Site Principal
# Delega autenticación a privacyIDEA via módulo Perl (rlm_perl)
server default {

    listen {
        type    = auth
        ipaddr  = *
        port    = 0
    }

    listen {
        type    = acct
        ipaddr  = *
        port    = 0
    }

    authorize {
        filter_username
        preprocess
        suffix
        eap {
            ok = return
        }
        files
        expiration
        logintime
        update control {
            Auth-Type := Perl
        }
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
        Auth-Type Perl {
            perl
        }
    }

    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        detail
        unix
        radutmp
        exec
        attr_filter.accounting_response
    }

    session {
    }

    post-auth {
        update {
            &reply: += &session-state:
        }
        exec
        remove_reply_message_if_eap
    }

    pre-proxy {
    }

    post-proxy {
        eap
    }
}